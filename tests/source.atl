val a = <Int>[
	1, 2, 3,
]

enum State {
	RUNNING, LOADED;
	func getName(): String {
		if (this == RUNNING) {
			return "RUNNING"
		}
		if (this == LOADED) {
			return "LOADED"
		}
		return "WTF"
	}
}

var b = State.RUNNING

println(when (b) {
	State.RUNNING -> "RUNNING"
	is State -> "WTF"
	else -> "LOADED"
})

b = State.LOADED

println(when (b) {
	State.RUNNING -> "RUNNING"
	else -> "LOADED"
})