val a = <Int>[
	1, 2, 3,
]

enum State {
	RUNNING, LOADED;
	func getName(): String {
		if (this == RUNNING) {
			return "RUNNING"
		}
		if (this == LOADED) {
			return "LOADED"
		}
		return "WTF"
	}
}

val b = State.RUNNING

println(State.RUNNING)
println(State.LOADED)
println(State.RUNNING == State.RUNNING)
println(State.RUNNING != State.RUNNING)
println(State.LOADED == State.RUNNING)
println(State.LOADED != State.RUNNING)
println(b == State.RUNNING)
println(b != State.RUNNING)
println(State.LOADED.getName())
println(b.getName())