
class M<T> {
	static var value: T?
	constructor (value: T) {
		println(this.value)
		this.value = value
		println(this.value)
	}
}

M<Int>(5)
M<String>("Hello")
println(M<Int>.value)
println(M<Float>.value)
println(M<String>.value)
// println(Map<Int, Int>.Map<Int, Int>())

class GAnimal() {
	func sound() = "Nothing"
}

class GDog extends GAnimal {
	constructor () {
		super()
	}
	func sound() = "Go"
}

class GCat extends GAnimal {
	constructor () {
		super()
	}
	func sound() = "Meow"
}

val a: GCat = GCat()
println(a.sound())