class TestLogicClass {
	val a = true

	func test() {
		assert((!a) == false, __FILE__, __LINE__)
		assert(-(!a) == 0, __FILE__, __LINE__)
	}
}

func testLogic() {

	val a = true && false
	println(!a)
	assert((!a) == true, __FILE__, __LINE__)

	val b = true || false
	assert(b == true && -b == -(1), __FILE__, __LINE__)

	val c = !false
	assert(c == true, __FILE__, __LINE__)

	val testLogicObj = TestLogicClass()
	testLogicObj.test()

	println("Passed ${__FUNC__}")
}

testLogic()