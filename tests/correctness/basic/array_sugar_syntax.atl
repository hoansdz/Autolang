
func testInputSugarSyntax(data: Array<Array<Int>>) {

}

func testArraySugarSyntax() {
	val list = <Array<Int>>[
		[1, 2, 3], 
		[4, 5, 6]
	]
	var sum = 0
	for (arr in list) {
		for (num in arr) {
			sum += num
		}
	}
	testInputSugarSyntax([[1, 2, 3], [4, 5, 6]])
	testInputSugarSyntax([[], []])
	testInputSugarSyntax([])
	assert(list is Array<Array<Int>>, __FILE__, __LINE__)
	assert(sum == 21, __FILE__, __LINE__)
	println("Passes ${__FUNC__}")
}

testArraySugarSyntax()