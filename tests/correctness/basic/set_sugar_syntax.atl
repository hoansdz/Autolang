func testInputSugarSyntax(data: Set<Set<Int>>) {

}

func testSetSugarSyntax() {
	val set = <Int>{
		1, 2, 3, 4, 5, 6, 7, 8, 9, 
		9, 8, 7, 6, 5, 4, 3, 2, 1
	}
	var sum = 0
	for (num in set) {
		sum += num
	}
	testInputSugarSyntax({{1, 2, 3}, {4, 5, 6}})
	testInputSugarSyntax({{}, {}})
	testInputSugarSyntax({})
	assert(set is Set<Int>, __FILE__, __LINE__)
	assert(sum == 45, __FILE__, __LINE__)
	println("Passes ${__FUNC__}")
}

testSetSugarSyntax()