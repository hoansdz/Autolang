// Global state to track forEach results since we don't have lambdas/closures
var globalSum = 0

// Named callback function to pass into forEach
func accumulateSum(value: Int) {
    globalSum += value
}

// Helper function to test nested sets
func testNestedSetSyntax(data: Set<Set<Int>>) {
    assert(data.size() == 3, __FILE__, __LINE__)
}

func testAllSetFeatures() {

    // 1. Test: __CLASS__() explicit constructor (and private create)
    val explicitSet = Set<Int>()
    explicitSet.insert(100)
    assert(explicitSet.size() == 1, __FILE__, __LINE__)
    assert(explicitSet.contains(100) == true, __FILE__, __LINE__)

    // 2. Test: insert, size, isEmpty, and Sugar Syntax
    val s1 = <Int>{1, 2, 3, 4, 5, 5, 4, 3, 2, 1} // Sugar syntax calls insert under the hood
    assert(s1.size() == 5, __FILE__, __LINE__)
    assert(s1.isEmpty() == false, __FILE__, __LINE__)

    // 3. Test: contains
    val s2 = <String>{"Apple", "Banana"}
    s2.insert("Orange")
    s2.insert("Apple") // Duplicate, should be ignored
    assert(s2.contains("Orange") == true, __FILE__, __LINE__)
    assert(s2.contains("Grapes") == false, __FILE__, __LINE__)

    // 4. Test: remove and clear
    s2.remove("Banana")
    assert(s2.size() == 2, __FILE__, __LINE__)
    assert(s2.contains("Banana") == false, __FILE__, __LINE__)
    
    s2.clear()
    assert(s2.size() == 0, __FILE__, __LINE__)
    assert(s2.isEmpty() == true, __FILE__, __LINE__)

    // // 5. Test: forEach (using a named function callback)
    val s3 = <Int>{10, 20, 30}
    globalSum = 0 // Reset global state
    s3.forEach(accumulateSum) // Passing the function by name
    assert(globalSum == 60, __FILE__, __LINE__)

    // // 6. Test: toArray (Public and Private)
    val s4 = <String>{"X", "Y", "Z"}
    val arr = s4.toArray() // Triggers the public toArray, which calls the private toArray
    assert(arr is Array<String>, __FILE__, __LINE__)
    assert(arr.size() == 3, __FILE__, __LINE__)
    assert(arr.contains("X") && arr.contains("Y") && arr.contains("Z"), __FILE__, __LINE__)

    // // 7. Test: union, intersect, difference
    val setA = <Int>{1, 2, 3, 4}
    val setB = <Int>{3, 4, 5, 6}

    val unionSet = setA.union(setB)
    assert(unionSet.size() == 6, __FILE__, __LINE__)

    val intersectSet = setA.intersect(setB)
    assert(intersectSet.size() == 2, __FILE__, __LINE__)
    assert(intersectSet.contains(3) && intersectSet.contains(4), __FILE__, __LINE__)

    val diffSet = setA.difference(setB)
    assert(diffSet.size() == 2, __FILE__, __LINE__)
    assert(diffSet.contains(1) && !diffSet.contains(3), __FILE__, __LINE__)

    // 8. Test: toString
    val str = s3.toString()
    assert(str is String, __FILE__, __LINE__)

    // 9. Test: Nested Sets
    testNestedSetSyntax({{1, 2}, {3, 4}, {1, 2}})

    println("Passed ${__FUNC__}")
}

// Execute the test
testAllSetFeatures()